{
  "name": "mock-meat-frozen-foods",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --config frontend/vite.config.js",
    "build": "node ./node_modules/vite/bin/vite.js build --config frontend/vite.config.js",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1 --config frontend/vite.config.js",
    "server": "node backend/server.js",
    "dev:full": "concurrently \"npm.cmd run dev\" \"npm.cmd run server\""
  },
  "dependencies": {
    "@getbrevo/brevo": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.5",
